---
import Steps from './Steps.astro';
---

<section id="inicio" class="hero-section">
  <div class="hero-inner">

    <!-- Lado izquierdo -->
    <div class="hero-left">
      <span class="hero-badge">Club de Exploradores</span>

    <h1 class="hero-title">
    Bienvenido a la tribu<br />
    de los pequeños<br />
    exploradores
    </h1>

      <p class="hero-body">
        Aquí comienza una nueva aventura. Después de armar tu puzzle y ver la historia, puedes seguir descubriendo animales, completar misiones divertidas y formar parte de una comunidad que aprende jugando.
      </p>

      <div class="hero-actions">
        <a href="#animales" class="btn-primary">Descubre personajes</a>
        <a href="#misiones" class="btn-secondary">Ver misiones</a>
      </div>
    </div>

    <!-- Lado derecho: placeholder para los pasos -->
    <div class="hero-right">
      <Steps />
    </div>

  </div>
</section>

<style>
    .hero-section {
    background: #eef3fb;
    /* Descontamos la altura del header sticky para que el contenido quede
       ópticamente centrado en el viewport visible, no desplazado hacia abajo. */
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    padding: 3rem 1.5rem;
    font-family: 'Nunito', sans-serif;
    box-sizing: border-box;
    }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* Badge */
  .hero-badge {
    display: inline-block;
    background: #c8f0d5;
    color: #1a7a3c;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  /* Título */
  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 900;
    color: #111827;
    line-height: 1.1;
    margin-bottom: 1.20rem;
    letter-spacing: -0.02em;
    margin-top: 1.20rem;
  }

  /* Cuerpo */
  .hero-body {
    font-size: 1.05rem;
    color: #4b5563;
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  /* Botones */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #22a55b;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.8rem 1.8rem;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover {
    background: #1a8a4a;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: #fff;
    color: #111827;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.8rem 1.8rem;
    border-radius: 10px;
    text-decoration: none;
    border: 1.5px solid #d1d5db;
    transition: border-color 0.2s, transform 0.15s;
  }

  .btn-secondary:hover {
    border-color: #9ca3af;
    transform: translateY(-1px);
  }

  /* Placeholder derecho */
  .placeholder-steps {
    background: rgba(255, 255, 255, 0.6);
    border: 2px dashed #c8d8f0;
    border-radius: 20px;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9ca3af;
    font-size: 0.95rem;
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .hero-body {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }
  }
</style>