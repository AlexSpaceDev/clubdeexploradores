---
import AnimalGrid from './AnimalGrid';
---

<section class="animales-section">
  <div class="animales-inner">

    <div class="section-label">SECCIÓN 1</div>
    <h2 class="section-title">Animales descubiertos</h2>
    <p class="section-subtitle">
      Acumula puntos en las misiones y desbloquea a cada explorador animal. ¡Toca una tarjeta cuando tengas los puntos!
    </p>

    <!-- React island con toda la lógica -->
    <AnimalGrid client:load />

  </div>
</section>

<style>
  .animales-section {
    background: #f0faf4;
    padding: 5rem 1.5rem;
    font-family: 'Nunito', sans-serif;
  }

  .animales-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: #22a55b;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    color: #111827;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1rem;
    color: #6b7280;
    max-width: 560px;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  /* Estilos del grid y tarjetas — scoped aquí para no contaminar */
  :global(.animal-grid-wrapper) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.grid-header) {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  :global(.points-badge) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: #fef3c7;
    color: #92400e;
    font-weight: 800;
    font-size: 0.95rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
  }

  :global(.unlocked-badge) {
    background: #d1fae5;
    color: #065f46;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
  }

  :global(.test-btn) {
    background: #f3f4f6;
    border: 2px dashed #d1d5db;
    color: #6b7280;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.4rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    width: fit-content;
    transition: background 0.2s;
  }

  :global(.test-btn:hover) {
    background: #e5e7eb;
  }

  :global(.animals-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  /* Tarjeta base */
  :global(.animal-card) {
    border-radius: 20px;
    padding: 1.4rem;
    font-family: 'Nunito', sans-serif;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 240px;
    position: relative;
    overflow: hidden;
  }

  /* LOCKED */
  :global(.animal-card.locked) {
    background: #f3f4f6;
    border: 2px solid #e5e7eb;
    align-items: center;
    justify-content: center;
    text-align: center;
    cursor: not-allowed;
  }

  :global(.animal-card.locked.can-unlock) {
    cursor: pointer;
    border-color: #22c55e;
    background: #f0fdf4;
  }

  :global(.card-emoji) {
    font-size: 3.5rem;
    line-height: 1;
  }

  :global(.blurred) {
    filter: grayscale(1) blur(2px) opacity(0.35);
  }

  :global(.lock-icon) {
    font-size: 1.8rem;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  :global(.card-cost) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  :global(.cost-label) {
    font-size: 0.8rem;
    font-weight: 700;
    color: #6b7280;
  }

  :global(.cost-badge) {
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    transition: background 0.3s, color 0.3s;
  }

  /* UNLOCKING */
  :global(.animal-card.unlocking) {
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  :global(.unlocking-text) {
    font-size: 1.1rem;
    font-weight: 900;
    color: #15803d;
  }

  /* UNLOCKED */
  :global(.animal-card.unlocked) {
    gap: 0.6rem;
  }

  :global(.animal-image-placeholder) {
    background: rgba(255,255,255,0.5);
    border-radius: 14px;
    height: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }

  :global(.placeholder-label) {
    font-size: 0.7rem;
    font-weight: 600;
    color: #9ca3af;
  }

  :global(.card-info) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.card-header) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  :global(.animal-name) {
    font-size: 1.15rem;
    font-weight: 900;
    color: #111827;
  }

  :global(.animal-tag) {
    font-size: 0.7rem;
    font-weight: 800;
    color: #fff;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.01em;
  }

  :global(.animal-desc) {
    font-size: 0.82rem;
    color: #374151;
    line-height: 1.5;
    font-weight: 600;
  }

  :global(.animal-stats) {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
    flex-wrap: wrap;
  }

  :global(.stat) {
    background: rgba(255,255,255,0.6);
    border-radius: 10px;
    padding: 0.35rem 0.6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    flex: 1;
    min-width: 60px;
  }

  :global(.stat-icon) {
    font-size: 0.85rem;
  }

  :global(.stat-value) {
    font-size: 0.8rem;
    font-weight: 800;
    color: #111827;
  }

  :global(.stat-label) {
    font-size: 0.65rem;
    font-weight: 600;
    color: #6b7280;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    :global(.animals-grid) {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>