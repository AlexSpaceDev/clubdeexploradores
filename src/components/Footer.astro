---
const year = new Date().getFullYear();
const instagramUrl = 'https://www.instagram.com/printandcraft.ec?igsh=MXVhbHpmbG02eWVsYQ==';

const navItems = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#animales', label: 'Animales' },
  { href: '#misiones', label: 'Misiones' },
  { href: '#proximos', label: 'Próximamente' },
];
---

<footer class="site-footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Pie de página</h2>

  <div class="footer-inner">

    {/* Columna de marca */}
    <div class="footer-brand">
      <a href="#inicio" class="footer-logo" aria-label="Ir al inicio">
        <img src="/images/logo-horizontal.png" alt="Club de Exploradores" />
      </a>
      <p class="footer-tagline">
        Aprende jugando con el <strong>Puzzle Animales Ecuador</strong>.
        Completa misiones, descubre animales y forma parte de la tribu de
        pequeños exploradores.
      </p>
    </div>

    {/* Navegación */}
    <nav class="footer-nav" aria-label="Navegación del pie">
      <h3 class="footer-heading">Explora</h3>
      <ul>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    {/* Social */}
    <div class="footer-social">
      <h3 class="footer-heading">Síguenos</h3>
      <a
        class="footer-ig"
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram de Print Craft"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        <div class="footer-ig-text">
          <span class="footer-ig-label">Instagram</span>
          <span class="footer-ig-handle">@printandcraft.ec</span>
        </div>
      </a>
    </div>
  </div>

  {/* Atribución Print Craft */}
  <div class="footer-brand-bar">
    <div class="footer-brand-bar-inner">
      <span class="footer-product-of">Un producto de</span>
      <img
        src="/images/printcraft-logo.png"
        alt="Print Craft"
        class="footer-printcraft-logo"
      />
    </div>
  </div>

  {/* Copyright */}
  <div class="footer-copy">
    <div class="footer-copy-inner">
      <span>© {year} Print Craft · Todos los derechos reservados.</span>
      <span class="footer-heart">Hecho con <span aria-hidden="true">❤️</span> en Ecuador</span>
    </div>
  </div>
</footer>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-footer {
    background: linear-gradient(180deg, #ffffff 0%, #f0faf4 100%);
    border-top: 1px solid #e5e7eb;
    font-family: 'Nunito', sans-serif;
    color: #374151;
    margin-top: 2rem;
  }

  /* ── Contenido principal en 3 columnas ────────────────────────────── */
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Columna de marca ─────────────────────────────────────────────── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 380px;
  }

  .footer-logo {
    display: inline-flex;
    padding: 0.25rem 0.4rem;
    border-radius: 12px;
    transition: background 0.2s ease, transform 0.2s ease;
    width: fit-content;
  }

  .footer-logo:hover {
    background: #dcfce7;
    transform: translateY(-1px);
  }

  .footer-logo img {
    height: 42px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.6;
    color: #4b5563;
    margin: 0;
  }

  .footer-tagline strong {
    color: #15803d;
    font-weight: 800;
  }

  /* ── Headings de columna ──────────────────────────────────────────── */
  .footer-heading {
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #22a55b;
    margin: 0 0 0.85rem;
  }

  /* ── Nav links ────────────────────────────────────────────────────── */
  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-nav a {
    color: #374151;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s ease, transform 0.2s ease;
    display: inline-block;
  }

  .footer-nav a:hover {
    color: #15803d;
    transform: translateX(3px);
  }

  /* ── Instagram ────────────────────────────────────────────────────── */
  .footer-ig {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    background: #ffffff;
    border: 2px solid #f3e8ff;
    border-radius: 14px;
    text-decoration: none;
    color: #7e22ce;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    font-weight: 800;
  }

  .footer-ig:hover {
    border-color: #d8b4fe;
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(168, 85, 247, 0.18);
  }

  .footer-ig svg {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .footer-ig-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .footer-ig-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: #9ca3af;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-ig-handle {
    font-size: 0.88rem;
    font-weight: 900;
    color: #111827;
  }

  /* ── Barra de atribución a Print Craft ────────────────────────────── */
  .footer-brand-bar {
    background: #f9fafb;
    border-top: 1px solid #f3f4f6;
    border-bottom: 1px solid #f3f4f6;
  }

  .footer-brand-bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .footer-product-of {
    font-size: 0.78rem;
    font-weight: 700;
    color: #6b7280;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .footer-printcraft-logo {
    height: 28px;
    width: auto;
    display: block;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .footer-printcraft-logo:hover { opacity: 1; }

  /* ── Copyright ────────────────────────────────────────────────────── */
  .footer-copy {
    background: #0f172a;
    color: #cbd5e1;
  }

  .footer-copy-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .footer-heart {
    color: #e2e8f0;
  }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2.5rem 1.25rem 1.75rem;
    }

    .footer-brand { max-width: 100%; }

    .footer-copy-inner {
      flex-direction: column;
      text-align: center;
      gap: 0.4rem;
    }

    .footer-brand-bar-inner {
      padding: 0.9rem 1.25rem;
    }
  }
</style>

<script>
  import { playSound } from '../lib/sounds';

  document.querySelectorAll<HTMLAnchorElement>('.site-footer a').forEach((a) => {
    a.addEventListener('click', () => playSound('press-button'));
  });
</script>
